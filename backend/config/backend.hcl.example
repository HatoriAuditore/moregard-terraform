bucket = "terraform"
key = "vcenter-clone/terraform.tfstate"
endpoints = {
  s3 = "https://s3.example.test"
}
region = "eu-central-1"
skip_region_validation = true
skip_credentials_validation = true
skip_requesting_account_id = true
skip_metadata_api_check = true
skip_s3_checksum = true
use_lockfile = true
access_key = ""
secret_key = ""
use_path_style = true
